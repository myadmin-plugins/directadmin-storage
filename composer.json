{
    "name": "detain/myadmin-directadmin-storage",
    "type": "myadmin-plugin",
    "description": "DirectAdmin Storage Plugin for MyAdmin - provides backup storage management via the DirectAdmin API",
    "keywords": [
        "directadmin",
        "administration",
        "storage",
        "backups",
        "myadmin"
    ],
    "license": "LGPL-2.1-only",
    "authors": [
        {
            "name": "Joe Huss",
            "homepage": "https:\/\/my.interserver.net\/"
        }
    ],
    "config": {
        "bin-dir": "vendor\/bin",
        "minimum-stability": "dev"
    },
    "require": {
        "php": ">=5.0.0",
        "ext-curl": "*",
        "symfony/event-dispatcher": "^5.0@stable",
        "detain/myadmin-plugin-installer": "dev-master"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Detain\\MyAdminDirectAdminStorage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Detain\\MyAdminDirectAdminStorage\\Tests\\": "tests/"
        }
    }
}
